{
  "manifest_version": 3,
  "name": "网页图片下载器",
  "version": "1.0.2",
  "description": "提取、筛选并下载当前网页上的所有图片",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "网页图片下载器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
